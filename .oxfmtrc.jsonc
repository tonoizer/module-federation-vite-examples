{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "trailingComma": "es5",
  "printWidth": 100,
  "semi": true,
  "singleQuote": false,
  "tabWidth": 2,
  "endOfLine": "lf",
  "ignorePatterns": [
    ".env*",
    "**/.__mf__temp/**",
    "**/.svelte-kit/**",
    "**/.nuxt/**",
  ],
}
