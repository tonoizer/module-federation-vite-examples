    "vite": "^8.0.0",
    "vue": "3.5.29"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "24.12.0",
    "typescript": "5.9.3",
    "vue-tsc": "2.2.8"
